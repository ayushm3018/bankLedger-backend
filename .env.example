# Server
PORT=3000

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://localhost:27017/banking-ledger

# JWT signing secret (use a long random string, e.g. `openssl rand -hex 32`)
JWT_SECRET=replace-me-with-a-long-random-string

# Gmail OAuth2 credentials (used by src/services/email.service.js)
# See: https://developers.google.com/identity/protocols/oauth2
CLIENT_ID=your-google-oauth-client-id
CLIENT_SECRET=your-google-oauth-client-secret
REFRESH_TOKEN=your-gmail-refresh-token
EMAIL_USER=your-gmail-address@gmail.com
